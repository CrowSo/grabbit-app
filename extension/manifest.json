{
  "manifest_version": 3,
  "name": "Grabbit",
  "version": "1.0.0",
  "description": "Download videos from YouTube, TikTok, Instagram, Facebook and more — directly to your computer.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Grabbit — Download this video"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.tiktok.com/*",
        "*://*.instagram.com/*",
        "*://*.facebook.com/*",
        "*://*.fb.watch/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.pinterest.com/*",
        "*://*.pin.it/*",
        "*://*.twitch.tv/*",
        "*://*.soundcloud.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}